# ASC Track Bot — Environment template.
# Copy to .env (or .env.test / .env.prod) and fill in real values.
# .env files are gitignored.

# ─── Runtime mode ───────────────────────────────────────────────────────
# Set ASC_ENV=test for the test workspace + test Discord guild,
# or ASC_ENV=prod for the production track Discord guild.
ASC_ENV=test

# ─── Discord bot ────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# In test mode, this MUST be set and MUST match the test guild the bot is in.
# Production track guild ID is read from bot_config.json (DISCORD_GUILD_ID).
TEST_DISCORD_GUILD_ID=

# Discord OAuth (used by the apply page to log in).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback

# ─── Notion ─────────────────────────────────────────────────────────────
NOTION_TOKEN=
# Master DB that contains the per-track row pages, each holding inline group DBs.
GROUP_PREVIEW_TEST_GROUP_DB_ID=
GROUP_PREVIEW_TEST_MEMBER_DB_ID=
GROUP_PREVIEW_TEST_TRACK_APPLICATION_DB_ID=
# (Optional) explicit override; if blank in test mode we fall back to NOTION_TOKEN.
GROUP_PREVIEW_TEST_NOTION_TOKEN=

# ─── Cohort ─────────────────────────────────────────────────────────────
CURRENT_COHORT=9
COHORT_START_DATE=2026-05-01
COHORT_END_DATE=2026-05-31

# ─── Supabase (optional, used for application cache) ────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Flask session ──────────────────────────────────────────────────────
FLASK_SECRET_KEY=
SESSION_COOKIE_SECURE=false
PUBLIC_API_BASE_URL=http://localhost:3000

# ─── Admin ──────────────────────────────────────────────────────────────
ADMIN_DISCORD_ID=
